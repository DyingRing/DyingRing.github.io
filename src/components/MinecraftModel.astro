---
// src/components/MinecraftModel.astro
// 组件的 Props 定义，接收 .litematic 文件的相对路径
export interface Props {
  filePath: string;
}
const { filePath } = Astro.props;
---

<div class="model-container">
  <canvas id="mc-canvas" style="width: 100%; height: 400px; border: 1px solid #ccc;"></canvas>
  <p class="model-caption">拖拽鼠标旋转视角，滚动滚轮进行缩放</p>
</div>

<script>
  // 使用内联脚本，直接运行在浏览器端
  import { ThreeStructureRenderer, LitematicLoader, loadDefaultPackResources } from '@mattzh72/lodestone';
  import { mat4 } from 'gl-matrix';
  import * as THREE from 'three';
  import { OrbitControls } from 'three/examples/jsm/controls/OrbitControls.js';

  async function init() {
    const canvas = document.getElementById('mc-canvas') as HTMLCanvasElement;
    if (!canvas) return;

    // 1. 加载资源与建筑文件
    const [{ resources }, response] = await Promise.all([
      loadDefaultPackResources(),
      fetch('/my_build.litematic') // 使用传入的 filePath
    ]);

    const buffer = await response.arrayBuffer();
    const structure = LitematicLoader.load(new Uint8Array(buffer));

    // 2. 初始化 Three.js 基础场景
    const scene = new THREE.Scene();
    scene.background = new THREE.Color(0x87CEEB); // 设置一个淡蓝色背景

    const camera = new THREE.PerspectiveCamera(45, canvas.clientWidth / canvas.clientHeight, 0.1, 1000);
    camera.position.set(10, 8, 10); // 调整初始视角

    const renderer = new THREE.WebGLRenderer({ canvas, antialias: true });
    renderer.setSize(canvas.clientWidth, canvas.clientHeight, false);

    // 3. 初始化 Lodestone 并渲染建筑
    const structureRenderer = new ThreeStructureRenderer(canvas, structure, resources);
    // 将 Lodestone 的渲染结果添加到 Three.js 场景中
    scene.add(structureRenderer.group);

    // 设置一个初始视图矩阵来定位建筑
    const view = mat4.create();
    mat4.lookAt(view, [10, 8, 10], [0, 0, 0], [0, 1, 0]); // 相机看向原点
    structureRenderer.drawStructure(view);

    // 4. 添加轨道控制器，实现可转动
    const controls = new OrbitControls(camera, renderer.domElement);
    controls.target.set(0, 0, 0); // 设置围绕建筑中心旋转
    controls.enableDamping = true; // 启用惯性效果
    controls.dampingFactor = 0.05;
    controls.update();

    // 5. 动画循环，持续渲染场景
    function animate() {
      requestAnimationFrame(animate);
      controls.update(); // 必须在每帧更新控制器
      renderer.render(scene, camera);
    }
    animate();

    // 6. 处理窗口大小变化
    window.addEventListener('resize', () => {
      if (!canvas) return;
      camera.aspect = canvas.clientWidth / canvas.clientHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(canvas.clientWidth, canvas.clientHeight, false);
    });
  }

  // 启动初始化函数
  init();
</script>