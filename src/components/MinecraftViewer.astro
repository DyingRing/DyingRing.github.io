---
// src/components/MinecraftViewer.astro

interface Props {
  modelPath: string;
  width?: string;
  height?: string;
}

const { modelPath, width = "100%", height = "500px" } = Astro.props;
---

<div class="mc-viewer-container" style="width: {width}; height: {height};">
  <canvas id="mc-canvas" style="width: 100%; height: 100%; display: block;"></canvas>
</div>

<script>
  import * as THREE from "three";
  import { OrbitControls } from "three/examples/jsm/controls/OrbitControls";
  import {
    LitematicLoader,
    ThreeStructureRenderer,
    loadDefaultPackResources,
  } from "@mattzh72/lodestone";

  (async () => {
    const canvas = document.getElementById("mc-canvas");
    if (!canvas) return;

    // 1. 加载 .litematic 文件
    const response = await fetch(modelPath);
    const buffer = await response.arrayBuffer();
    const structure = LitematicLoader.load(new Uint8Array(buffer));

    // 2. 获取模型元数据（可选，用于调试或展示信息）
    const metadata = LitematicLoader.getMetadata(new Uint8Array(buffer));
    console.log(`Building: ${metadata.name}, Blocks: ${metadata.totalBlocks}`);

    // 3. 加载默认材质包
    const { resources } = await loadDefaultPackResources();

    // 4. 初始化渲染器（复用 existing canvas）
    const renderer = new ThreeStructureRenderer(canvas, structure, resources);
    
    // 调整视口大小
    const resizeObserver = new ResizeObserver(() => {
      const rect = canvas.parentElement?.getBoundingClientRect();
      if (rect) {
        canvas.width = rect.width;
        canvas.height = rect.height;
        renderer.setViewport(0, 0, rect.width, rect.height);
      }
    });
    resizeObserver.observe(canvas.parentElement!);
    
    // 5. 创建 Three.js 场景、相机，并接入 OrbitControls
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(45, 1, 0.1, 1000);
    camera.position.set(10, 10, 15);
    camera.lookAt(0, 0, 0);

    const controls = new OrbitControls(camera, canvas);
    controls.enableDamping = true;      // 惯性效果
    controls.dampingFactor = 0.05;
    controls.autoRotate = false;
    controls.enableZoom = true;
    controls.zoomSpeed = 1.2;
    controls.enablePan = true;
    
    // 辅助：添加一些光源（Lodestone 内部可能自带，但为确保视觉，可自行添加）
    const ambientLight = new THREE.AmbientLight(0x404060);
    scene.add(ambientLight);
    const dirLight = new THREE.DirectionalLight(0xffffff, 1);
    dirLight.position.set(5, 10, 7);
    scene.add(dirLight);
    
    // 6. 动画循环
    function animate() {
      requestAnimationFrame(animate);
      controls.update(); // 更新轨道控制
      const viewMatrix = camera.matrixWorldInverse.elements;
      const projectionMatrix = camera.projectionMatrix.elements;
      renderer.draw(viewMatrix, projectionMatrix);
    }
    animate();

    // 可选：添加简单的地面辅助线（调试用，可不加）
    // const gridHelper = new THREE.GridHelper(30, 20, 0x888888, 0x444444);
    // scene.add(gridHelper);
  })();
</script>